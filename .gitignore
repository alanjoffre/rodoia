# === Segredos e ambiente (NUNCA versionar) ===
.env
.env.*
!.env.example
*.pem
*.key
credentials.json
service-account*.json
.secrets.baseline.local

# === Dados: brutos/processados vão para o DVC, NUNCA para o Git ===
# O DVC cria um .gitignore por diretório rastreado (ignora os dados, mantém o
# apontador .dvc). Abaixo é a rede de segurança por extensão — mesmo que alguém
# esqueça o `dvc add`, arquivo de dado bruto não entra no Git.
*.csv
*.parquet
*.duckdb
*.sqlite
# Índice vetorial local do RAG (regenerável a partir do corpus + código).
/data/processed/qdrant_normas/

# Trilha de auditoria da API (dados de runtime).
/logs/

# Exceções que DEVEM ser versionadas:
!data/**/README.md
!data/**/*.dvc

# === Artefatos de modelo / experimentos (via DVC/MLflow, não no Git) ===
/models/
/artifacts/
/mlruns/
*.safetensors
*.bin
*.gguf
*.ckpt
*.pt
*.pth
!**/*.dvc

# === Python ===
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.python-version.local

# === Notebooks / ferramentas ===
.ipynb_checkpoints/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
.dvc/cache/
.dvc/tmp/
.dvc/config.local

# === SO / editor ===
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
env.sh
data/raw/lener_br/
data/raw/volume_pedagio/
data/processed/volume.duckdb
data/processed/volume_pedagio.parquet
