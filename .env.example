# ==========================================================================
# RodoIA — modelo de variáveis de ambiente.
# Copie para `.env` (que É IGNORADO pelo Git) e preencha com valores reais.
# NUNCA commite o `.env`. Este arquivo (.env.example) só tem placeholders.
# ==========================================================================

# --- Provedor de LLM para RAG/agente (Fases 1 e 4) ---
# Abstraído atrás de interface; troque de provedor sem tocar no código.
LLM_PROVIDER=openai            # openai | anthropic | local_vllm
LLM_API_KEY=coloque-sua-chave-aqui
LLM_MODEL=gpt-4o-mini

# --- Embeddings (Fase 1) ---
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# --- Banco vetorial (Fase 1) ---
VECTOR_BACKEND=qdrant          # qdrant | pgvector
QDRANT_URL=http://localhost:6333
POSTGRES_DSN=postgresql://usuario:senha@localhost:5432/rodoia  # pragma: allowlist secret

# --- Serving do modelo próprio via vLLM (Fase 2) ---
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=rodoia-antt-ft

# --- MLOps (Fase 5) ---
MLFLOW_TRACKING_URI=http://localhost:5000

# --- Cloud (Fase 5) — preencher só quando for para nuvem ---
AWS_REGION=us-east-1
# Credenciais de cloud via perfil/role, NUNCA hard-coded aqui.

# --- Runtime ---
LOG_LEVEL=INFO
SEED=42
